# Dependencies
node_modules
.pnp
.pnp.js

# Capacitor — the native iOS project is generated fresh in CI (codemagic.yaml),
# so we don't commit it. (capacitor.config.json IS committed.)
/ios
/android
.capacitor
*.ipa

# Next.js
.next/
out/

# Misc
.DS_Store
*.pem
.env*

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel
.vercel

# Railway
.railway

# Data — local JSON store (never commit real user data)
data/*.json
# Config/seed data (not user data) — keep in git so Railway deploys have them
!data/announcements.json
!data/campaign-placements.json

# OS
Thumbs.db

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Backup files
*.bak
*.backup

# Stripe CLI binary (be specific — don't block app/api/stripe/)
stripe-cli
stripe/stripe

# next-pwa generated worker files (regenerated on every build)
public/worker-*.js

# Claude AI assistant files
.claude/
memory/

/lib/generated/prisma
