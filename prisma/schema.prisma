generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String    @id
  email                    String    @unique
  name                     String
  passwordHash             String
  plan                     String    @default("free")
  createdAt                String

  // Stripe billing
  stripeCustomerId         String?
  stripeSubscriptionId     String?   @unique

  // Activity tracking
  calcCount                Int       @default(0)
  budgetCalcCount          Int       @default(0)
  locationLookups          Int       @default(0)
  activeDays               String[]  @default([])
  streak                   Int       @default(0)
  badges                   String[]  @default([])

  // Referral system
  referralCode             String?   @unique
  referredBy               String?
  referralCount            Int       @default(0)
  referralProMonthsEarned  Int       @default(0)
  referralRewardCredited   Boolean   @default(false)
  referralCredits          Json      @default("[]")

  // Beta / Pro trial
  isBetaTester             Boolean   @default(false)
  isProTrial               Boolean   @default(false)
  betaProExpiry            String?

  // Email verification
  emailVerified            Boolean   @default(false)
  emailVerifyToken         String?
  emailVerifyExpires       String?

  // Password reset
  passwordResetToken       String?
  passwordResetExpires     String?

  // Profile
  phone                    String?
  displayName              String?
  smsOptIn                 Boolean   @default(false)

  // Gas price alerts
  priceAlertThreshold      Float?
  lastPriceAlertSentAt     String?

  // Login tracking
  loginCount               Int       @default(0)
  lastLoginAt              String?

  // Fill-up reminders
  fillupReminderDays       Int?
  lastFillupReminderSentAt String?

  // Streak rewards
  streakMilestonesHit      Int[]     @default([])
  streakCredits            Json      @default("[]")

  // Signup locale
  locale                   String?

  // Email campaign drip — trial sequence (5 steps, day 0/3/10/21/28)
  emailCampaignStep        Int?
  emailCampaignEnrolledAt  String?
  emailOptOut              Boolean   @default(false)

  // Paid user drip — post-upgrade sequence (P1 immediate, P2 day30, P3 day60, P4 day330 annual only)
  paidCampaignStep         Int?      // 0=not enrolled, 1=P1 sent, 2=P2 sent, 3=P3 sent, 4=P4 sent
  paidCampaignEnrolledAt   String?   // ISO timestamp of first upgrade — used to schedule P2/P3/P4
  stripeInterval           String?   // 'monthly' | 'annual' — P4 only fires for annual

  // Email verification reminder
  verifyReminderSentAt     String?   // ISO timestamp of last verification reminder email

  // Ambassador Program
  ambassadorProForLife     Boolean   @default(false)

  // Comp Ambassador drip — 5-email sequence for comped members (C1 sent immediately on comp grant)
  compCampaignStep         Int?      // 0=not enrolled, 1=C1 sent, 2=C2 sent … 5=C5 sent (done)
  compCampaignEnrolledAt   String?   // ISO timestamp of comp grant — used to schedule C2–C5

  // Internal / testing
  isTestAccount            Boolean   @default(false)

  // Fleet Phase 1 — driver roster (names only; no sub-accounts yet)
  fleetDrivers             String[]  @default([])

  vehicles                 Vehicle[]
}

model Vehicle {
  id              String  @id
  userId          String
  name            String
  gallons         Float
  vin             String?
  year            String?
  make            String?
  model           String?
  trim            String?
  fuelType        String?
  epaId           String?
  currentOdometer Float?
  vehicleSpecs    Json?
  createdAt       String

  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GiveawayDraw {
  id           String  @id
  month        String  // "YYYY-MM" — one draw per month
  winnerId     String
  winnerName   String
  winnerEmail  String
  entryCount   Int     // winner's entries at draw time
  totalEntries Int     // full pool size at draw time
  drawnAt      String  // ISO timestamp
  notes        String?

  @@unique([month])
}
