generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String    @id
  email                    String    @unique
  name                     String
  passwordHash             String
  plan                     String    @default("free")
  createdAt                String
  stripeCustomerId         String?
  stripeSubscriptionId     String?   @unique
  calcCount                Int       @default(0)
  budgetCalcCount          Int       @default(0)
  locationLookups          Int       @default(0)
  activeDays               String[]  @default([])
  streak                   Int       @default(0)
  badges                   String[]  @default([])
  referralCode             String?   @unique
  referredBy               String?
  referralCount            Int       @default(0)
  referralProMonthsEarned  Int       @default(0)
  referralRewardCredited   Boolean   @default(false)
  referralCredits          Json      @default("[]")
  isProTrial               Boolean   @default(false)
  trialExpiresAt           String?
  emailVerified            Boolean   @default(false)
  emailVerifyToken         String?
  emailVerifyExpires       String?
  passwordResetToken       String?
  passwordResetExpires     String?
  phone                    String?
  displayName              String?
  priceAlertThreshold      Float?
  lastPriceAlertSentAt     String?
  loginCount               Int       @default(0)
  lastLoginAt              String?
  fillupReminderDays       Int?
  lastFillupReminderSentAt String?
  streakMilestonesHit      Int[]     @default([])
  streakCredits            Json      @default("[]")
  locale                   String?
  emailCampaignStep        Int?
  emailCampaignEnrolledAt  String?
  emailOptOut              Boolean   @default(false)
  isTestAccount            Boolean   @default(false)
  fleetDrivers             String[]  @default([])
  paidCampaignEnrolledAt   String?
  paidCampaignStep         Int?
  stripeInterval           String?
  verifyReminderSentAt           String?
  verifyReminderBonusEntries     Int       @default(0)
  ambassadorProForLife     Boolean   @default(false)
  compCampaignEnrolledAt   String?
  compCampaignStep         Int?
  smsOptIn                 Boolean   @default(false)
  engagementEnrolledAt     String?
  engagementStep           Int?
  engagementTrack          String?
  milestoneFillup10Sent    Boolean   @default(false)
  milestoneMpgSent         Boolean   @default(false)
  milestoneReferral1Sent   Boolean   @default(false)
  earlyUpgradeBonusEntries Int       @default(0)
  phoneBonusEntries        Int       @default(0)
  emailVerifyBonusGranted  Boolean   @default(false)
  smsOptInDate             String?
  avatarUrl                String?
  preferredFillLevel       Int?     // % 0-100 — default target fill for calculators
  monthlyFuelBudget        Float?   // $ amount — monthly spending target
  garageBonusDays          String[]  @default([])
  garageLastOpenedDate     String?
  fleetCompanyName         String?
  fleetLogoUrl             String?
  // Smartcar OAuth — stored per-user (covers all their authorized vehicles)
  smartcarAccessToken      String?   // short-lived; refresh before use
  smartcarRefreshToken     String?   // long-lived; use to get new access token
  smartcarTokenExpiry      String?   // ISO timestamp of access token expiry
  vehicles                 Vehicle[]
}

model Vehicle {
  id              String  @id
  userId          String
  name            String
  gallons         Float
  vin             String?
  year            String?
  make            String?
  model           String?
  trim            String?
  fuelType        String?
  epaId           String?
  currentOdometer   Float?
  vehicleSpecs      Json?
  createdAt         String
  // Smartcar integration — links this GasCap vehicle to a Smartcar vehicle ID
  smartcarVehicleId String?   // Smartcar vehicle UUID (from OAuth vehicle list)
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Fillup {
  id              String  @id
  userId          String
  vehicleId       String?
  vehicleName     String
  date            String   // YYYY-MM-DD
  gallonsPumped   Float
  pricePerGallon  Float
  totalCost       Float
  odometerReading Float?
  fuelLevelBefore Float?
  stationName     String?
  notes           String?
  driverLabel     String?
  fuelGrade       String?  // "regular" | "midgrade" | "premium" | "diesel" | "e85"
  receiptThumb    String?  // base64-compressed JPEG thumbnail of receipt (data URL)
  createdAt       String

  @@index([userId])
  @@index([userId, date])
}

model EmailLog {
  id        String  @id
  userId    String
  userEmail String
  userName  String
  type      String
  subject   String
  sentAt    String
  error     String?
  status    String  @default("sent")

  @@index([userId])
  @@index([sentAt])
  @@index([type])
  @@index([status])
}

model GiveawayDraw {
  id           String  @id
  month        String  @unique
  winnerId     String
  winnerName   String
  winnerEmail  String
  entryCount   Int
  totalEntries Int
  drawnAt      String
  notes        String?
  claimedAt    String?  // set when winner confirms receipt; null = unclaimed
}

model CampaignPlacement {
  id              String  @id
  code            String  @unique
  campaign        String
  station         String  @default("")
  address         String?
  city            String?
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  placement       String
  headlineVariant String
  landingPath     String
  notes           String?
  createdAt       String
  active          Boolean @default(true)
  featured        Boolean @default(false)

  @@index([code])
}

model DeletedAccountLog {
  id          String  @id
  // Snapshot of user info captured before deletion
  userId      String
  name        String
  email       String
  plan        String
  // Metadata
  deletedAt   String
  reason      String? // "user_request" | "admin_action" | "violation" etc.
  notes       String? // optional free-text from admin
  // Was a confirmation email sent?
  emailSent   Boolean @default(false)

  @@index([email])
  @@index([deletedAt])
}
