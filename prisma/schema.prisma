generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String    @id
  email                    String    @unique
  name                     String
  passwordHash             String?   // null for Google OAuth users
  plan                     String    @default("free")
  createdAt                String
  stripeCustomerId         String?
  stripeSubscriptionId     String?   @unique
  calcCount                Int       @default(0)
  budgetCalcCount          Int       @default(0)
  locationLookups          Int       @default(0)
  activeDays               String[]  @default([])
  streak                   Int       @default(0)
  badges                   String[]  @default([])
  referralCode             String?   @unique
  referredBy               String?
  referralCount            Int       @default(0)
  referralProMonthsEarned  Int       @default(0)
  referralRewardCredited   Boolean   @default(false)
  referralCredits          Json      @default("[]")
  isProTrial               Boolean   @default(false)
  trialExpiresAt           String?
  emailVerified            Boolean   @default(false)
  emailVerifyToken         String?
  emailVerifyExpires       String?
  passwordResetToken       String?
  passwordResetExpires     String?
  phone                    String?
  displayName              String?
  priceAlertThreshold      Float?
  lastPriceAlertSentAt     String?
  // True once we've alerted for the current below-threshold drop; reset when the
  // price goes back above the threshold. Drives one-alert-per-drop (not daily).
  priceAlertNotified       Boolean   @default(false)
  loginCount               Int       @default(0)
  lastLoginAt              String?
  fillupReminderDays       Int?
  lastFillupReminderSentAt String?
  streakMilestonesHit      Int[]     @default([])
  streakCredits            Json      @default("[]")
  locale                   String?
  emailCampaignStep        Int?
  emailCampaignEnrolledAt  String?
  emailOptOut              Boolean   @default(false)
  isTestAccount            Boolean   @default(false)
  fleetDrivers             String[]  @default([])
  paidCampaignEnrolledAt   String?
  paidCampaignStep         Int?
  stripeInterval           String?
  foundingMemberAt         DateTime?
  verifyReminderSentAt           String?
  verifyReminderBonusEntries     Int       @default(0)
  ambassadorProForLife     Boolean   @default(false)
  compCampaignEnrolledAt   String?
  compCampaignStep         Int?
  smsOptIn                 Boolean   @default(false)
  engagementEnrolledAt     String?
  engagementStep           Int?
  engagementTrack          String?
  milestoneFillup10Sent    Boolean   @default(false)
  milestoneMpgSent         Boolean   @default(false)
  milestoneReferral1Sent   Boolean   @default(false)
  earlyUpgradeBonusEntries Int       @default(0)
  phoneBonusEntries        Int       @default(0)
  firstCalcBonusEntries    Int       @default(0)   // +entries granted on a user's first calculation (activation reward)
  emailVerifyBonusGranted  Boolean   @default(false)
  smsOptInDate             String?
  avatarUrl                String?
  preferredFillLevel       Int?     // % 0-100 — default target fill for calculators
  monthlyFuelBudget        Float?   // $ amount — monthly spending target
  garageBonusDays          String[]  @default([])
  garageLastOpenedDate     String?
  fleetCompanyName         String?
  fleetLogoUrl             String?
  // Daily bonus gift box — awarded once per calendar day (3–15 entries, random)
  dailyBonusDays           String[]  @default([])   // YYYY-MM-DD dates claimed (idempotency)
  dailyBonusEntries        Int       @default(0)     // running total across all time
  // Native iOS push (Capacitor) — APNs device token + last-updated timestamp
  iosPushToken             String?
  iosPushTokenAt           String?
  // Win-back ("come back to Pro") campaign for lapsed free users (expired trial).
  // winbackStep: 0 = not started, 1–3 = last email sent in the 3-step sequence.
  winbackStep              Int       @default(0)
  winbackLastSentAt        String?
  winbackStartedAt         String?   // when the win-back sequence began (drives the 3-day offer deadline)
  // Lifetime Perks add-on — annual $9.99 renewal granting +20 giveaway entries + vacation voucher.
  // Null = never subscribed or lapsed. Kept separate from stripeSubscriptionId (that slot is used
  // by the primary Pro Lifetime one-time payment or monthly/annual sub).
  lifetimePerksUntil       DateTime?
  lifetimePerksSubId       String?
  // OTP passwordless sign-in — one-time session token issued after code verification,
  // consumed by the credentials-otp NextAuth provider (2-min TTL).
  otpSessionToken          String?
  otpSessionExpires        String?
  otpCode                  String?
  otpCodeExpires           String?
  otpCodeName              String?
  priceReportEntries       Int       @default(0)
  gigLogEntries            Int       @default(0)
  signupPlatform           String?   // 'web' | 'ios' | 'android'
  userMode                 String?   // 'personal' | 'gig' | 'rental' | 'fleet'
  vehicles                 Vehicle[]
  priceReports             PriceReport[]
  gigFillups               GigFillup[]
  gigMileage               GigMileage[]
}

model OtpCode {
  email   String   @id
  code    String
  name    String   @default("")
  expires DateTime
}

model Vehicle {
  id              String  @id
  userId          String
  name            String
  gallons         Float
  vin             String?
  year            String?
  make            String?
  model           String?
  trim            String?
  fuelType        String?
  fuelTypeConfirmedByUser Boolean @default(false)
  epaId           String?
  currentOdometer   Float?
  vehicleSpecs      Json?
  createdAt         String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Fillup {
  id              String  @id
  userId          String
  vehicleId       String?
  vehicleName     String
  date            String   // YYYY-MM-DD
  gallonsPumped   Float
  pricePerGallon  Float
  totalCost       Float
  odometerReading Float?
  fuelLevelBefore Float?
  stationName     String?
  notes           String?
  driverLabel     String?
  fuelGrade       String?  // "regular" | "midgrade" | "premium" | "diesel" | "e85"
  receiptThumb    String?  // base64-compressed JPEG thumbnail of receipt (data URL)
  createdAt       String

  @@index([userId])
  @@index([userId, date])
}

model GigFillup {
  id             String  @id
  userId         String
  date           String   // YYYY-MM-DD
  gallons        Float
  pricePerGallon Float
  totalCost      Float
  station        String?
  odometer       Float?
  platform       String?  // "uber" | "lyft" | "doordash" | "instacart" | "spark" | "amazon_flex" | "shipt" | "courier" | "other"
  notes          String?
  createdAt      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
}

model GigMileage {
  id            String  @id
  userId        String
  date          String   // YYYY-MM-DD
  startOdometer Float?
  endOdometer   Float?
  miles         Float
  platform      String?  // same enum as GigFillup.platform
  category      String   @default("business") // "business" | "personal"
  notes         String?
  createdAt     String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
}

model EmailLog {
  id        String  @id
  userId    String
  userEmail String
  userName  String
  type      String
  subject   String
  sentAt    String
  error     String?
  status    String  @default("sent")

  @@index([userId])
  @@index([sentAt])
  @@index([type])
  @@index([status])
}

model GiveawayDraw {
  id           String  @id
  month        String  @unique
  winnerId     String
  winnerName   String
  winnerEmail  String
  entryCount   Int
  totalEntries Int
  drawnAt      String
  notes        String?
  claimedAt    String?  // set when winner confirms receipt; null = unclaimed
}

model CampaignPlacement {
  id              String  @id
  code            String  @unique
  campaign        String
  station         String  @default("")
  address         String?
  city            String?
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  placement       String
  headlineVariant String
  landingPath     String
  notes           String?
  createdAt       String
  active          Boolean @default(true)
  featured        Boolean @default(false)

  @@index([code])
}

model DeletedAccountLog {
  id          String  @id
  // Snapshot of user info captured before deletion
  userId      String
  name        String
  email       String
  plan        String
  // Metadata
  deletedAt   String
  reason      String? // "user_request" | "admin_action" | "violation" etc.
  notes       String? // optional free-text from admin
  // Was a confirmation email sent?
  emailSent   Boolean @default(false)

  @@index([email])
  @@index([deletedAt])
}

model Gift {
  id                 String  @id            // gift_xxxxxxxx
  code               String  @unique        // redemption code, e.g. GASCAP-7K2P-9QX4
  occasion           String  @default("gift") // gift | fathers-day | birthday | holiday
  plan               String  @default("pro")
  interval           String  @default("lifetime")
  amountPaid         Int                    // cents actually charged
  purchaserEmail     String
  purchaserUserId    String?
  recipientEmail     String?                // null = buyer keeps the code
  recipientName      String?
  giftMessage        String?
  deliverToRecipient Boolean @default(false)
  stripeSessionId    String?
  stripePaymentId    String?
  status             String  @default("paid") // paid | redeemed | refunded
  redeemedByUserId   String?
  redeemedAt         String?
  createdAt          String

  @@index([code])
  @@index([purchaserEmail])
  @@index([status])
}

// User-submitted testimonials. One per user (keyed by userId, upsert on edit).
// New reviews default approved=false → moderated at /admin/reviews before going public.
model Review {
  id          String  @id
  userId      String  @unique
  userName    String
  rating      Int
  text        String
  vehicleName String?
  plan        String  @default("free")
  lifetime    Boolean @default(false)
  approved    Boolean @default(false)
  createdAt   String
  updatedAt   String

  @@index([approved])
}

// Gauge scan results stored for QA and future model improvement.
// Additive-only: no existing models touched.
model GaugeScanLog {
  id               String  @id @default(cuid())
  userId           String
  detectedPercent  Int?
  confirmedPercent Int
  confidence       Int
  gaugeType        String
  reason           String?
  vehicleId        String?
  vehicleName      String?
  tankSize         Float?
  createdAt        String

  @@index([userId])
  @@index([createdAt])
}

model PriceReport {
  id          String  @id
  userId      String
  placeId     String
  stationName String
  lat         Float
  lng         Float
  grade       String
  price       Float
  createdAt   String

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([placeId])
  @@index([createdAt])
}
