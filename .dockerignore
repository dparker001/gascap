# Never bake secrets into the image
.env
.env.*
.env.local

# Build artifacts that will be regenerated
node_modules
.next/

# Dev / debug files
npm-debug.log*
.DS_Store
Thumbs.db

# Local JSON data store (runtime-only files)
data/*.json
# …except the gas-price seed: lib/gasPrices.ts imports it at BUILD time, so
# excluding it breaks `next build` in the Docker image (Railway deploy failure).
!data/gas-prices-seed.json

# Prisma generated client (regenerated by postinstall)
lib/generated/

# Git
.git
.gitignore

# Claude
.claude/
memory/
